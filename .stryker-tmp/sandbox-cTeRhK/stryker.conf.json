{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing config - 70/50/30 thresholds",
  "testRunner": "vitest",
  "coverageAnalysis": "all",
  "vitest": {
    "configFile": "vitest.mutate.config.ts",
    "related": false
  },
  "thresholds": {
    "high": 70,
    "low": 50,
    "break": 50
  },
  "mutate": [
    "extensions/cali-product-workflow/adapters/{base,cli-adapter,event-dispatcher,generic,index,ui-adapter,ui-factory}.ts",
    "extensions/cali-product-workflow/adapters/commands/*.ts"
  ],
  "reporters": [
    "clear-text",
    "html"
  ],
  "htmlReporter": {
    "fileName": "stryker-reports/index.html"
  }
}