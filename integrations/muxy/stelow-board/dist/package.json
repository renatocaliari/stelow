{
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "vite": "^7.3.5"
  },
  "displayName": "Stelow Board",
  "description": "Stelow workflow board panel (Shape Up → critique → gate → interface → planning → execution)",
  "muxy": {
    "$schema": "https://raw.githubusercontent.com/muxy-app/muxy/main/docs/extensions/schema/manifest.schema.json",
    "commands": [
      {
        "action": {
          "kind": "togglePanel",
          "panel": "pipeline"
        },
        "defaultShortcut": "cmd+shift+p",
        "id": "toggle-pipeline",
        "title": "Stelow Board: Toggle Panel"
      },
      {
        "id": "refresh-pipeline",
        "title": "Stelow Board: Refresh"
      },
      {
        "id": "sw-next-cmd",
        "title": "Workflow: Execute /sw-next"
      },
      {
        "id": "sw-abort-cmd",
        "title": "Workflow: Execute /sw-abort"
      },
      {
        "id": "sw-complete-cmd",
        "title": "Workflow: Execute /sw-complete"
      },
      {
        "id": "sw-archive-cmd",
        "title": "Stelow: Execute /sw-archive"
      }
    ],
    "panels": [
      {
        "entry": "panel/index.html",
        "headerButtons": [
          {
            "command": "refresh-pipeline",
            "icon": {
              "symbol": "arrow.clockwise"
            },
            "id": "refresh",
            "tooltip": "Refresh Pipeline"
          }
        ],
        "icon": {
          "symbol": "rectangle.3.group"
        },
        "id": "pipeline",
        "mode": "pinned",
        "position": "right",
        "title": "Stelow Board"
      }
    ],
    "events": [
      "project.switched",
      "worktree.switched"
    ],
    "permissions": [
      "panels:write",
      "commands:exec",
      "panes:read",
      "projects:read",
      "worktrees:read"
    ],
    "topbarItems": [
      {
        "command": "toggle-pipeline",
        "icon": {
          "symbol": "rectangle.3.group"
        },
        "id": "pipeline",
        "tooltip": "Toggle Pipeline Panel"
      }
    ]
  },
  "name": "stelow-muxy",
  "private": true,
  "scripts": {
    "build": "vite build && node scripts/copy-manifest.mjs",
    "dev": "vite",
    "update-skill": "node -e \"const fs=require('fs'),p=require('path');const url='https://raw.githubusercontent.com/muxy-app/muxy/main/Muxy/Resources/skills/muxy-extension/SKILL.md';fetch(url).then(r=>{if(!r.ok)throw new Error('HTTP '+r.status);return r.text()}).then(t=>{for(const d of ['.claude/skills/muxy-extension','.agents/skills/muxy-extension']){fs.mkdirSync(d,{recursive:true});fs.writeFileSync(p.join(d,'SKILL.md'),t);console.log('Updated '+p.join(d,'SKILL.md'))}}).catch(e=>{console.error('Failed to update skill:',e.message);process.exit(1)})\""
  },
  "type": "module",
  "version": "0.2.7-alpha"
}
