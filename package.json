{
  "name": "@renatocaliari/pi-product-workflow",
  "version": "0.2.0-alpha",
  "description": "Product workflow for AI coding agents: Shape Up + Interface + Tech Planning + Critique + Gate. Includes 16 product skills: workflow, short-cycle, opportunity-mapping, job-to-be-done, evolutionary, ads, business-models, health, marketplace-playbook, open-source, pricing, promotions, trust-building, multi-method-market-analysis, scope-executor, testing-ai-code. Works with pi.dev, OpenCode, Claude Code, and Codex.",
  "keywords": [
    "pi-skill",
    "pi-extension",
    "ai-coding-agent",
    "workflow",
    "shape-up",
    "product-planning",
    "product-management",
    "safe-change"
  ],
  "license": "MIT",
  "author": "Cali",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cali/pi-product-workflow.git"
  },
  "homepage": "https://github.com/cali/pi-product-workflow#readme",
  "bugs": {
    "url": "https://github.com/cali/pi-product-workflow/issues"
  },
  "exports": {
    ".": "./extensions/cali-product-workflow/index.js",
    "./skills": "./skills/",
    "./extensions": "./extensions"
  },
  "peerDependencies": {
    "typebox": "*"
  },
  "optionalPeerDependencies": {
    "@capyup/pi-goal": ">=0.6.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-tui": "*",
    "@juicesharp/rpiv-ask-user-question": ">=1.6.0",
    "@plannotator/pi-extension": ">=0.19.0",
    "pi-agent-codebase-workflows": "*",
    "pi-autoresearch": ">=0.1.0",
    "pi-intercom": ">=0.6.0",
    "pi-subagents": ">=0.24.0",
    "pi-supervisor": ">=0.4.0",
    "cali-short-cycle-product": "*",
    "cali-opportunity-mapping": "*",
    "cali-job-to-be-done-framework": "*",
    "cali-evolutionary-principles": "*",
    "cali-product-ads": "*",
    "cali-product-business-models": "*",
    "cali-product-health": "*",
    "cali-product-marketplace-playbook": "*",
    "cali-product-open-source": "*",
    "cali-product-pricing": "*",
    "cali-product-promotions": "*",
    "cali-product-trust-building": "*",
    "context-mode": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "extensions/cali-product-workflow/",
    "skills/",
    "scripts/",
    "install.sh",
    "cali-product-workflow.schema.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".claude-plugin/",
    ".codex-plugin/",
    ".opencode-plugin/"
  ],
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:skills": "vitest run tests/skills",
    "test:artifacts": "vitest run tests/artifacts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "./scripts/test-ci.sh",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "mutate": "stryker run",
    "test:mutation": "stryker run",
    "version:sync": "node scripts/version-sync.mjs",
    "version": "npm run version:sync && git add extensions/cali-product-workflow-pi/package.json"
  },
  "devDependencies": {
    "@marcfargas/pi-test-harness": "^0.5.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
